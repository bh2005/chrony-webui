# API-Schlüssel für die WebUI (beliebig, min. 16 Zeichen)
CHRONYWEBUI_API_KEY=changeme-please-set-a-secure-key

# Pfad zur chrony.conf (Standard Debian)
CHRONYWEBUI_CHRONY_CONF_PATH=/etc/chrony/chrony.conf

# Pfad zu chronyc
CHRONYWEBUI_CHRONYC_PATH=/usr/bin/chronyc

# Kommando für chrony reload nach Konfigurationsänderung
CHRONYWEBUI_RELOAD_COMMAND=systemctl reload chrony
